# ==================================================
# ZIROSTACK .htaccess
# Clean Routing • Performance • Security
# ==================================================

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# --------------------------------------------------
# ENVIRONMENT DETECTION
# --------------------------------------------------
RewriteCond %{HTTP_HOST} ^localhost [NC]
SetEnv ZS_ENV dev

RewriteCond %{HTTP_HOST} !^localhost [NC]
SetEnv ZS_ENV prod

# --------------------------------------------------
# FORCE HTTPS + REMOVE WWW (PROD ONLY)
# --------------------------------------------------
RewriteCond %{ENV:ZS_ENV} =prod
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.*)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# --------------------------------------------------
# BLOCK DIRECT ACCESS TO INTERNAL FOLDERS
# --------------------------------------------------
RewriteRule ^(config|includes|node_modules|pages/private|dbschema|vendor)/ - [F,L]

# --------------------------------------------------
# BLOCK DIRECT ACCESS TO /pages/ FROM URL BAR
# --------------------------------------------------
RewriteCond %{THE_REQUEST} \s/pages/ [NC]
RewriteRule ^ pages/public/error.php [L]

# --------------------------------------------------
# STATIC ASSETS (DO NOT TOUCH)
# --------------------------------------------------
RewriteCond %{REQUEST_URI} ^/assets/ [NC,OR]
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2?|ttf|eot|mp4)$ [NC]
RewriteRule ^ - [L]

# --------------------------------------------------
# API ROUTES (if used later)
# --------------------------------------------------
RewriteRule ^api/(.*)$ api/$1 [L,QSA]

# --------------------------------------------------
# HOME ROUTE (IMPORTANT)
# --------------------------------------------------
# / OR /index → pages/public/index.php
RewriteRule ^(index)?/?$ pages/public/index.php [L,QSA]

# --------------------------------------------------
# PUBLIC PAGES (CLEAN URLS)
# --------------------------------------------------
RewriteRule ^about/?$ pages/public/about.php [L,QSA]
RewriteRule ^services/?$ pages/public/services.php [L,QSA]
RewriteRule ^projects/?$ pages/public/projects.php [L,QSA]
RewriteRule ^team/?$ pages/public/team.php [L,QSA]
RewriteRule ^contact/?$ pages/public/contact.php [L,QSA]

# --------------------------------------------------
# PROJECT DETAIL PAGES (projects/*)
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/pages/public/projects/$1.php -f
RewriteRule ^([a-zA-Z0-9_-]+)/?$ pages/public/projects/$1.php [L,QSA]

# --------------------------------------------------
# SPA / FALLBACK (OPTIONAL BUT SAFE)
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ pages/public/index.php [L,QSA]

</IfModule>

# ==================================================
# SECURITY HEADERS
# ==================================================
<IfModule mod_headers.c>
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ==================================================
# COMPRESSION
# ==================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE application/font-woff2
    # Do not compress already-compressed binary formats
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif|woff2|mp4|zip|gz)$ no-gzip
</IfModule>

# ==================================================
# CACHING
# ==================================================
<IfModule mod_expires.c>
ExpiresActive On

# Images
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"

# Fonts
ExpiresByType application/font-woff2 "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"

# CSS / JS
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# --------------------------------------------------
# Disable directory listing
# --------------------------------------------------
Options -Indexes
